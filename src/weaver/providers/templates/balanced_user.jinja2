<policy>
honorifics: {{ honorific_policy }}
</policy>
{% if glossary_terms %}
<glossary>
{% for term in glossary_terms -%}
{{ term.source }}	{{ term.target }}	{{ term.category or "" }}	{{ term.notes or "" }}
{% endfor -%}
</glossary>
{% endif %}
{% if characters %}
<characters>
{% for c in characters -%}
{{ c.jp_name }}	{{ c.en_name }}	{{ c.gender or "" }}	{{ c.role or "" }}	{{ c.notes or "" }}
{% endfor -%}
</characters>
{% endif %}
{% if previous_segments %}
<context>
{% for source, translation in previous_segments -%}
[PREV-{{ loop.revindex }}] {{ source }}
→ {{ translation }}
{% if not loop.last %}
{% endif -%}
{% endfor %}
</context>
{% endif %}
<source>
{{ source_text }}
</source>
